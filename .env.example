# Copiar a .env.sandbox o .env.production según corresponda.
# NINGUNO de estos archivos se versiona. Ver .gitignore.

# Entorno: sandbox | production
APP_ENV=sandbox
VITE_APP_ENV=sandbox

# Firebase (solo en producción — obtener de Firebase Console)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Hardware mocks (solo en sandbox/tests)
# KRETZ_MOCK_MODE=normal      # normal | timeout | garbage | disconnect
# KRETZ_MOCK_INTERVAL_MS=3000
# KRETZ_MOCK_DISCONNECT_AFTER=5
# FISCAL_MOCK_MODE=normal     # normal | timeout | http_error | malformed_response | disconnect
