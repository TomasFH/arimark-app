{
  "name": "carniceria-app",
  "version": "0.1.0",
  "private": true,
  "description": "App de gestión para carnicerías — offline-first, Electron + React",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:sandbox": "cross-env APP_ENV=sandbox VITE_APP_ENV=sandbox concurrently \"pnpm run build:electron:watch\" \"pnpm run vite:dev\"",
    "dev:prod": "cross-env APP_ENV=production VITE_APP_ENV=production concurrently \"pnpm run build:electron:watch\" \"pnpm run vite:dev\"",
    "vite:dev": "vite",
    "build:electron:watch": "tsc -p tsconfig.node.json --watch",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "build:prod": "cross-env APP_ENV=production VITE_APP_ENV=production pnpm run build:main && pnpm run build:renderer && electron-builder --config electron-builder.config.cjs",
    "build:sandbox": "cross-env APP_ENV=sandbox VITE_APP_ENV=sandbox pnpm run build:main && pnpm run build:renderer && electron-builder --config electron-builder.config.cjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate:sandbox": "cross-env APP_ENV=sandbox tsx electron/db/migrate-cli.ts",
    "test": "vitest run --config vitest.config.ts && vitest run --config vitest.config.renderer.ts",
    "test:main": "vitest run --config vitest.config.ts",
    "test:renderer": "vitest run --config vitest.config.renderer.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage && vitest run --config vitest.config.renderer.ts --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.41.0",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.0",
    "firebase": "^11.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "serialport": "^12.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.4",
    "@napi-rs/keyring": "^1.1.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.15.21",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/coverage-v8": "^3.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.1",
    "electron": "^35.3.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.27.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vitest": "^3.2.3"
  },
  "build": {
    "extends": "./electron-builder.config.cjs"
  }
}
